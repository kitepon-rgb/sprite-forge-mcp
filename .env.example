# Copy to .env and fill in your values. .env is gitignored (never committed).
# A real shell environment variable always overrides the matching line here.

# --- Required for generation/editing ---
# ComfyUI HTTP endpoint on your GPU machine (must serve ComfyUI's HTTP+WS API)
SPRITEFORGE_COMFY_URL=http://gpu-box:8188

# --- Adopt target (where accepted sprites are written) ---
# Point at your game's sprite directory; defaults to a placeholder otherwise.
SPRITEFORGE_RPGDEV_SPRITES=/path/to/your-game/public/assets/sprites

# --- Required only for LoRA training (backend SSHes the GPU box) ---
# SSH user@host of the GPU box (key-based auth assumed)
SPRITEFORGE_BOX_SSH=user@gpu-box
# Windows account on the box — drives the box paths below (ComfyUI / sd-scripts / sf-lora staging)
SPRITEFORGE_BOX_USER=youruser

# --- Optional: AI prompt-crafting (shells your own claude / codex CLI; no API key) ---
# Project root whose CLAUDE.md/context the CLI loads (default: this repo root)
# SPRITEFORGE_PROMPT_PROJECT_DIR=/path/to/your-project
# SPRITEFORGE_PROMPT_CLI=claude        # "claude" | "codex"
# SPRITEFORGE_PROMPT_MODEL=opus

# --- Optional advanced box-path overrides (default: derived from SPRITEFORGE_BOX_USER) ---
# SPRITEFORGE_BOX_SDXL_CKPT=C:\Users\youruser\ComfyUI\models\checkpoints\Illustrious-XL-v2.0.safetensors
# SPRITEFORGE_BOX_LORA_DIR=C:\Users\youruser\ComfyUI\models\loras
# SPRITEFORGE_BOX_SFLORA=C:\Users\youruser\sf-lora
# SPRITEFORGE_BOX_SDSCRIPTS=C:\Users\youruser\sd-scripts
# SPRITEFORGE_BOX_TRAIN_VENV=C:\Users\youruser\sf-lora-venv

# --- Optional backend host/port + matting ---
# SPRITEFORGE_HOST=127.0.0.1
# SPRITEFORGE_PORT=8765
# SPRITEFORGE_MATTE_MODEL=birefnet-general
